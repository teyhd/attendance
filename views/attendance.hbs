<section class="space-y-4">
  <div class="bg-white shadow rounded-lg p-4 space-y-4">
    <div class="flex flex-col xl:flex-row xl:items-end gap-3">
      <div class="flex-1">
        <h1 class="text-xl font-semibold text-gray-900">Посещаемость</h1>
        <div class="mt-1 text-sm text-gray-600">{{displayDate selectedDate}}</div>
      </div>

      {{#if success}}
        <div data-flash class="rounded border border-green-200 bg-green-50 text-green-800 px-3 py-2 text-sm">
          {{#if (eq success "created")}}Отметка сохранена.{{/if}}
          {{#if (eq success "updated")}}Отметка обновлена.{{/if}}
          {{#if (eq success "deleted")}}Отметка удалена.{{/if}}
          {{#if (eq success "resolved")}}Вопрос закрыт.{{/if}}
        </div>
      {{/if}}
      {{#if error}}
        <div data-flash class="rounded border border-red-200 bg-red-50 text-red-800 px-3 py-2 text-sm">{{error}}</div>
      {{/if}}

      <form id="attendance-controls-form" method="get" action="/attendance" class="flex flex-col sm:flex-row gap-2 sm:items-end">
        <label class="text-sm text-gray-700">
          <span class="block mb-1">Класс</span>
          <select id="class-select" data-testid="class-select" name="class" class="w-full sm:w-36 rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500">
            {{#each classes}}
              <option value="{{id}}" {{#if (eq ../selectedClass id)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
        </label>
        <label class="text-sm text-gray-700">
          <span class="block mb-1">Дата</span>
          <input id="attendance-date" name="date" value="{{selectedDate}}" type="date" class="w-full sm:w-40 rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" />
        </label>
        <label class="text-sm text-gray-700">
          <span class="block mb-1">Поиск</span>
          <input name="q" value="{{q}}" type="search" class="w-full sm:w-52 rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" />
        </label>
        <input type="hidden" name="filter" value="{{activeFilter}}" />
        <button type="submit" class="px-4 py-2 bg-gray-900 text-white rounded hover:bg-gray-800">Показать</button>
      </form>
    </div>

    {{#if summary}}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
        <div class="border rounded p-3">
          <div class="text-xs text-gray-500">В классе</div>
          <div class="text-2xl font-semibold text-gray-900">{{summary.students_total}}</div>
        </div>
        <div class="border rounded p-3">
          <div class="text-xs text-gray-500">На дату</div>
          <div class="text-2xl font-semibold text-gray-900">{{summary.absent_students}}</div>
        </div>
        <div class="border rounded p-3">
          <div class="text-xs text-gray-500">Без причины</div>
          <div class="text-2xl font-semibold text-amber-700">{{summary.without_reason_count}}</div>
        </div>
        <div class="border rounded p-3">
          <div class="text-xs text-gray-500">Внимание</div>
          <div class="text-2xl font-semibold text-red-700">{{summary.needs_attention_count}}</div>
        </div>
      </div>
    {{/if}}

    <div class="flex flex-wrap gap-2">
      {{#each filters}}
        <a href="{{{href}}}" class="px-3 py-1.5 text-sm rounded border {{#if active}}bg-indigo-600 text-white border-indigo-600{{else}}bg-white text-gray-700 hover:bg-gray-50{{/if}}">{{name}}</a>
      {{/each}}
    </div>
  </div>

  <div class="grid lg:grid-cols-[320px_1fr] gap-4">
    <aside class="bg-white shadow rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Ученики</h2>
        <span class="text-sm text-gray-500">{{children.length}}</span>
      </div>
      {{#if children.length}}
        <div class="space-y-1.5">
          {{#each children}}
            <a href="{{{href}}}" class="block border rounded px-3 py-2 hover:border-indigo-400 hover:bg-indigo-50 transition {{#if isActive}}border-indigo-500 bg-indigo-50{{/if}}">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <div class="font-medium text-gray-900 truncate">{{name}}</div>
                  <div class="mt-1 flex flex-wrap gap-1">
                    {{#if hasCurrentAbsence}}
                      <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-800">сейчас</span>
                    {{/if}}
                    {{#if hasFutureAbsence}}
                      <span class="text-xs px-2 py-0.5 rounded-full bg-sky-100 text-sky-800">будущая</span>
                    {{/if}}
                    {{#if needsAttention}}
                      <span class="text-xs px-2 py-0.5 rounded-full bg-red-100 text-red-800">внимание</span>
                    {{/if}}
                    {{#if hasMissingReason}}
                      <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-800">без причины</span>
                    {{/if}}
                    {{#if isFrequent}}
                      <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-700">часто</span>
                    {{/if}}
                  </div>
                </div>
                {{#if dayAbsence}}
                  <span class="shrink-0 text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-700">{{dayAbsence.reason_name}}</span>
                {{/if}}
              </div>
            </a>
          {{/each}}
        </div>
      {{else}}
        <div class="text-sm text-gray-500">Нет учеников по текущему фильтру.</div>
      {{/if}}
    </aside>

    <div class="bg-white shadow rounded-lg p-4 space-y-4">
      {{#if selectedChild}}
        <div class="flex flex-col xl:flex-row xl:items-start xl:justify-between gap-3">
          <div class="min-w-0">
            <p class="text-sm text-gray-500">Класс {{#with (findById classes selectedChild.classId)}}{{name}}{{/with}}</p>
            <h2 class="text-xl font-semibold text-gray-900 truncate">{{selectedChild.name}}</h2>
            {{#if studentContext.last_comment}}
              <p class="mt-1 text-sm text-gray-600">{{studentContext.last_comment}}</p>
            {{/if}}
            <a href="/attendance/analytics?class={{selectedClass}}" class="mt-2 inline-flex text-sm font-medium text-indigo-700 hover:text-indigo-900">Аналитика класса</a>
          </div>
          <div class="grid grid-cols-3 gap-2 text-center">
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold">{{studentContext.absence_count}}</div>
              <div class="text-xs text-gray-500">30 дней</div>
            </div>
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold text-red-700">{{studentContext.needs_attention_count}}</div>
              <div class="text-xs text-gray-500">внимание</div>
            </div>
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold text-amber-700">{{studentContext.without_reason_count}}</div>
              <div class="text-xs text-gray-500">без причины</div>
            </div>
          </div>
        </div>

        <div data-attendance-tabs data-default-tab="{{#if canManage}}mark{{else}}active{{/if}}" class="space-y-4">
          <div class="flex flex-wrap gap-2 border-b border-gray-200">
            {{#if canManage}}
              <button type="button" data-attendance-tab="mark" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">Отметка</button>
            {{/if}}
            <button type="button" data-attendance-tab="active" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">
              Активные <span class="ml-1 text-xs text-gray-500">{{currentAbsences.length}}</span>
            </button>
            <button type="button" data-attendance-tab="history" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">
              История <span class="ml-1 text-xs text-gray-500">{{childAbsences.length}}</span>
            </button>
          </div>

          {{#if canManage}}
            <section data-attendance-panel="mark" class="overflow-hidden rounded-lg border border-indigo-100 bg-white">
              <div class="flex flex-col gap-3 border-b border-indigo-100 bg-indigo-50 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                  <h3 class="font-semibold text-gray-900">Новая отметка</h3>
                  <div class="mt-0.5 truncate text-sm text-gray-600">{{selectedChild.name}}</div>
                </div>
                <div class="grid grid-cols-3 gap-1 rounded-lg border border-gray-200 bg-white p-1 shadow-sm">
                  <button type="button" data-fill="today" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-indigo-50 hover:text-indigo-700">Сегодня</button>
                  <button type="button" data-fill="day-end" title="До {{schoolDay.end_label}}" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-indigo-50 hover:text-indigo-700">До конца дня</button>
                  <button type="button" data-fill="lesson" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-indigo-50 hover:text-indigo-700">Один урок</button>
                </div>
              </div>

              <form id="new-absence-form" method="post" action="/attendance" class="space-y-4 p-4" data-school-day-start="{{schoolDay.start_input}}" data-school-day-end="{{schoolDay.end_input}}">
                <input type="hidden" name="childId" value="{{selectedChild.id}}" />
                <input type="hidden" name="classId" value="{{selectedChild.classId}}" />
                <input type="hidden" name="date" value="{{selectedDate}}" />
                <input type="hidden" name="filter" value="{{activeFilter}}" />
                <input type="hidden" name="q" value="{{q}}" />
                <input type="hidden" name="source" value="mentor" />

                <div class="grid gap-3 md:grid-cols-2">
                  <label class="block">
                    <span class="mb-1 block text-xs font-semibold uppercase text-gray-500">Начало</span>
                    <input id="absence-from" name="from" type="datetime-local" value="{{defaultFrom}}" required class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-base text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" />
                  </label>
                  <label class="block">
                    <span class="mb-1 block text-xs font-semibold uppercase text-gray-500">Окончание</span>
                    <input id="absence-to" name="to" type="datetime-local" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-base text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500" />
                  </label>
                </div>

                <div class="grid gap-3 md:grid-cols-[240px_1fr]">
                  <label class="block">
                    <span class="mb-1 block text-xs font-semibold uppercase text-gray-500">Причина</span>
                    <select id="reason" name="reason" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-base font-medium text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500">
                      {{#each reasons}}
                        <option value="{{code}}">{{name}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label class="block">
                    <span class="mb-1 block text-xs font-semibold uppercase text-gray-500">Комментарий</span>
                    <textarea id="comment" name="comment" rows="2" maxlength="1000" class="min-h-[4.5rem] w-full rounded border border-gray-300 bg-white px-3 py-2 text-base text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500"></textarea>
                  </label>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div data-reason-note class="hidden rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900"></div>
                  <button type="submit" class="h-11 w-full rounded bg-indigo-600 px-6 text-base font-semibold text-white shadow-sm hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 sm:w-auto">Сохранить</button>
                </div>
              </form>
            </section>
          {{/if}}

          <section data-attendance-panel="active" class="space-y-3 {{#if canManage}}hidden{{/if}}">
            <div class="rounded border p-3">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-semibold text-gray-900">Активные</h3>
                <span class="text-sm text-gray-500">{{currentAbsences.length}}</span>
              </div>

              {{#if currentAbsences.length}}
                {{#if activeNowAbsences.length}}
                  <div>
                    <div class="mb-1 text-xs font-semibold uppercase text-gray-500">Сейчас</div>
                    <div class="divide-y divide-gray-100">
                      {{#each activeNowAbsences}}
                        <div class="py-2 flex flex-col xl:flex-row xl:items-start xl:justify-between gap-2">
                          <div>
                            <div class="text-sm font-medium text-gray-900">{{period_label}}</div>
                            <div class="mt-1 flex flex-wrap gap-1 text-xs">
                              <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{{reason_name}}</span>
                              <span class="px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">{{confirmation_label}}</span>
                              <span class="px-2 py-0.5 rounded-full {{#if needs_attention}}bg-red-100 text-red-800{{else}}bg-green-50 text-green-700{{/if}}">{{attention_label}}</span>
                            </div>
                            {{#if comment}}
                              <div class="text-xs text-gray-500 mt-1">{{comment}}</div>
                            {{/if}}
                          </div>
                          {{#if (and ../canManage needs_attention)}}
                            <form method="post" action="/attendance/{{id}}/resolve">
                              <input type="hidden" name="childId" value="{{student_id}}" />
                              <input type="hidden" name="classId" value="{{class_id}}" />
                              <input type="hidden" name="date" value="{{../selectedDate}}" />
                              <input type="hidden" name="filter" value="{{../activeFilter}}" />
                              <input type="hidden" name="q" value="{{../q}}" />
                              <button type="submit" class="px-3 py-1.5 text-sm bg-green-600 text-white rounded hover:bg-green-700">Закрыть вопрос</button>
                            </form>
                          {{/if}}
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if futureAbsences.length}}
                  <div class="{{#if activeNowAbsences.length}}mt-3 border-t border-gray-100 pt-3{{/if}}">
                    <div class="mb-1 text-xs font-semibold uppercase text-gray-500">Запланировано</div>
                    <div class="divide-y divide-gray-100">
                      {{#each futureAbsences}}
                        <div class="py-2 flex flex-col xl:flex-row xl:items-start xl:justify-between gap-2">
                          <div>
                            <div class="text-sm font-medium text-gray-900">{{period_label}}</div>
                            <div class="mt-1 flex flex-wrap gap-1 text-xs">
                              <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{{reason_name}}</span>
                              <span class="px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">{{confirmation_label}}</span>
                              <span class="px-2 py-0.5 rounded-full {{#if needs_attention}}bg-red-100 text-red-800{{else}}bg-green-50 text-green-700{{/if}}">{{attention_label}}</span>
                            </div>
                            {{#if comment}}
                              <div class="text-xs text-gray-500 mt-1">{{comment}}</div>
                            {{/if}}
                          </div>
                          {{#if (and ../canManage needs_attention)}}
                            <form method="post" action="/attendance/{{id}}/resolve">
                              <input type="hidden" name="childId" value="{{student_id}}" />
                              <input type="hidden" name="classId" value="{{class_id}}" />
                              <input type="hidden" name="date" value="{{../selectedDate}}" />
                              <input type="hidden" name="filter" value="{{../activeFilter}}" />
                              <input type="hidden" name="q" value="{{../q}}" />
                              <button type="submit" class="px-3 py-1.5 text-sm bg-green-600 text-white rounded hover:bg-green-700">Закрыть вопрос</button>
                            </form>
                          {{/if}}
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}
              {{else}}
                <p class="text-sm text-gray-500">Активных и будущих отметок нет.</p>
              {{/if}}
            </div>
          </section>

          <section data-attendance-panel="history" class="hidden">
            <div class="rounded border p-3">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-semibold text-gray-900">История</h3>
                <span class="text-sm text-gray-500">{{childAbsences.length}}</span>
              </div>
              {{#if childAbsences.length}}
                <div class="divide-y divide-gray-100">
                  {{#each childAbsences}}
                    <div class="py-3">
                      <div class="grid xl:grid-cols-[1fr_220px] gap-3">
                        <div class="min-w-0">
                          <div class="text-sm font-medium text-gray-900">{{period_label}}</div>
                          <div class="mt-1 flex flex-wrap gap-1 text-xs">
                            <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{{reason_name}}</span>
                            <span class="px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">{{confirmation_label}}</span>
                            <span class="px-2 py-0.5 rounded-full {{#if needs_attention}}bg-red-100 text-red-800{{else}}bg-green-50 text-green-700{{/if}}">{{attention_label}}</span>
                          </div>
                          {{#if comment}}
                            <div class="text-sm text-gray-600 mt-1">{{comment}}</div>
                          {{/if}}
                        </div>
                        {{#if ../canManage}}
                          <div class="flex flex-wrap xl:justify-end gap-2">
                            <details class="relative">
                              <summary class="cursor-pointer select-none px-3 py-1.5 text-sm bg-gray-100 rounded hover:bg-gray-200">Изменить</summary>
                              <div class="mt-2 xl:absolute xl:right-0 xl:z-10 w-full xl:w-[560px] bg-white border rounded shadow p-3">
                                <form method="post" action="/attendance/{{id}}/update" class="space-y-3">
                                  <input type="hidden" name="childId" value="{{student_id}}" />
                                  <input type="hidden" name="classId" value="{{class_id}}" />
                                  <input type="hidden" name="date" value="{{../selectedDate}}" />
                                  <input type="hidden" name="filter" value="{{../activeFilter}}" />
                                  <input type="hidden" name="q" value="{{../q}}" />
                                  <div class="grid sm:grid-cols-2 gap-2">
                                    <label class="text-sm text-gray-700">
                                      <span class="block mb-1">Начало</span>
                                      <input name="from" type="datetime-local" value="{{starts_at_input}}" required class="w-full rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" />
                                    </label>
                                    <label class="text-sm text-gray-700">
                                      <span class="block mb-1">Окончание</span>
                                      <input name="to" type="datetime-local" value="{{ends_at_input}}" class="w-full rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" />
                                    </label>
                                  </div>
                                  <div class="grid sm:grid-cols-3 gap-2">
                                    <label class="text-sm text-gray-700">
                                      <span class="block mb-1">Причина</span>
                                      <select name="reason" class="w-full rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500">
                                        {{#each ../reasons}}
                                          <option value="{{code}}" {{#if (eq ../reason_code code)}}selected{{/if}}>{{name}}</option>
                                        {{/each}}
                                      </select>
                                    </label>
                                    <label class="text-sm text-gray-700">
                                      <span class="block mb-1">Подтверждение</span>
                                      <select name="confirmationStatus" class="w-full rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500">
                                        <option value="confirmed" {{#if (eq confirmation_status "confirmed")}}selected{{/if}}>Подтверждено</option>
                                        <option value="reported" {{#if (eq confirmation_status "reported")}}selected{{/if}}>Со слов</option>
                                        <option value="needs_clarification" {{#if (eq confirmation_status "needs_clarification")}}selected{{/if}}>Уточнить</option>
                                        <option value="system_conflict" {{#if (eq confirmation_status "system_conflict")}}selected{{/if}}>Конфликт</option>
                                      </select>
                                    </label>
                                    <label class="text-sm text-gray-700">
                                      <span class="block mb-1">Внимание</span>
                                      <select name="attentionStatus" class="w-full rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500">
                                        <option value="normal" {{#if (eq attention_status "normal")}}selected{{/if}}>Обычная</option>
                                        <option value="needs_attention" {{#if (eq attention_status "needs_attention")}}selected{{/if}}>Требует внимания</option>
                                        <option value="resolved" {{#if (eq attention_status "resolved")}}selected{{/if}}>Закрыто</option>
                                      </select>
                                    </label>
                                  </div>
                                  <label class="text-sm text-gray-700">
                                    <span class="block mb-1">Комментарий</span>
                                    <textarea name="comment" rows="2" maxlength="1000" class="w-full rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500">{{comment}}</textarea>
                                  </label>
                                  <button type="submit" class="px-3 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700">Обновить</button>
                                </form>
                              </div>
                            </details>
                            {{#if needs_attention}}
                              <form method="post" action="/attendance/{{id}}/resolve">
                                <input type="hidden" name="childId" value="{{student_id}}" />
                                <input type="hidden" name="classId" value="{{class_id}}" />
                                <input type="hidden" name="date" value="{{../selectedDate}}" />
                                <input type="hidden" name="filter" value="{{../activeFilter}}" />
                                <input type="hidden" name="q" value="{{../q}}" />
                                <button type="submit" class="px-3 py-1.5 text-sm bg-green-50 text-green-700 rounded hover:bg-green-100">Закрыть</button>
                              </form>
                            {{/if}}
                            <form method="post" action="/attendance/{{id}}/delete" onsubmit="return confirm('Удалить отметку об отсутствии?');">
                              <input type="hidden" name="childId" value="{{student_id}}" />
                              <input type="hidden" name="classId" value="{{class_id}}" />
                              <input type="hidden" name="date" value="{{../selectedDate}}" />
                              <input type="hidden" name="filter" value="{{../activeFilter}}" />
                              <input type="hidden" name="q" value="{{../q}}" />
                              <button type="submit" class="px-3 py-1.5 text-sm bg-red-50 text-red-700 rounded hover:bg-red-100">Удалить</button>
                            </form>
                          </div>
                        {{/if}}
                      </div>
                    </div>
                  {{/each}}
                </div>
              {{else}}
                <p class="text-sm text-gray-500">Отметок пока нет.</p>
              {{/if}}
            </div>
          </section>
        </div>
      {{else}}
        <div class="text-sm text-gray-500">В выбранном классе нет учеников.</div>
      {{/if}}
    </div>
  </div>
</section>

<script>
(() => {
  const controlsForm = document.getElementById('attendance-controls-form');
  const classSelect = document.getElementById('class-select');
  classSelect?.addEventListener('change', () => controlsForm?.requestSubmit());

  document.querySelectorAll('[data-flash]').forEach((node) => {
    window.setTimeout(() => {
      node.classList.add('opacity-0');
      window.setTimeout(() => node.remove(), 250);
    }, 3500);
  });

  const tabsRoot = document.querySelector('[data-attendance-tabs]');
  if (tabsRoot) {
    const storageKey = 'attendance.activeTab';
    const buttons = Array.from(tabsRoot.querySelectorAll('[data-attendance-tab]'));
    const panels = Array.from(tabsRoot.querySelectorAll('[data-attendance-panel]'));
    const available = new Set(buttons.map((button) => button.dataset.attendanceTab));
    const defaultTab = tabsRoot.dataset.defaultTab || buttons[0]?.dataset.attendanceTab || '';
    const hashTab = window.location.hash.startsWith('#attendance-') ? window.location.hash.replace('#attendance-', '') : '';
    const storedTab = sessionStorage.getItem(storageKey) || '';

    const activeClasses = ['bg-white', 'border-gray-200', 'text-gray-900', 'shadow-sm'];
    const inactiveClasses = ['bg-gray-50', 'border-transparent', 'text-gray-600', 'hover:bg-white'];

    const activate = (tab, updateLocation = false) => {
      const nextTab = available.has(tab) ? tab : defaultTab;
      buttons.forEach((button) => {
        const active = button.dataset.attendanceTab === nextTab;
        button.classList.toggle('bg-white', active);
        button.classList.toggle('border-gray-200', active);
        button.classList.toggle('text-gray-900', active);
        button.classList.toggle('shadow-sm', active);
        button.classList.toggle('bg-gray-50', !active);
        button.classList.toggle('border-transparent', !active);
        button.classList.toggle('text-gray-600', !active);
        button.classList.toggle('hover:bg-white', !active);
      });
      panels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.attendancePanel !== nextTab));
      sessionStorage.setItem(storageKey, nextTab);
      if (updateLocation) window.history.replaceState(null, '', `#attendance-${nextTab}`);
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => activate(button.dataset.attendanceTab, true));
    });

    activate(available.has(hashTab) ? hashTab : (available.has(storedTab) ? storedTab : defaultTab));
  }

  const applyReasonState = (form, syncStatuses = false) => {
    const reasonSelect = form.querySelector('select[name="reason"]');
    const commentField = form.querySelector('textarea[name="comment"]');
    if (!reasonSelect || !commentField) return;

    const reason = reasonSelect.value;
    const note = form.querySelector('[data-reason-note]');
    commentField.required = reason === 'other';
    commentField.placeholder = reason === 'without_reason'
      ? 'Что нужно уточнить'
      : reason === 'other'
        ? 'Опишите причину'
        : 'Комментарий';
    if (note) {
      const message = reason === 'without_reason'
        ? 'Отметка попадет в «Требуют внимания».'
        : reason === 'other'
          ? 'Комментарий обязателен.'
          : '';
      note.textContent = message;
      note.classList.toggle('hidden', !message);
    }

    if (!syncStatuses) return;
    const confirmationSelect = form.querySelector('select[name="confirmationStatus"]');
    const attentionSelect = form.querySelector('select[name="attentionStatus"]');
    if (reason === 'without_reason') {
      if (confirmationSelect) confirmationSelect.value = 'needs_clarification';
      if (attentionSelect && attentionSelect.value === 'normal') attentionSelect.value = 'needs_attention';
    }
    if (reason === 'other') {
      if (confirmationSelect && confirmationSelect.value === 'needs_clarification') confirmationSelect.value = 'reported';
      if (attentionSelect && attentionSelect.value === 'needs_attention') attentionSelect.value = 'normal';
    }
  };

  document.querySelectorAll('form').forEach((form) => {
    const reasonSelect = form.querySelector('select[name="reason"]');
    if (!reasonSelect) return;
    applyReasonState(form);
    reasonSelect.addEventListener('change', () => applyReasonState(form, true));
  });

  const fromInput = document.getElementById('absence-from');
  const toInput = document.getElementById('absence-to');
  if (!fromInput || !toInput) return;
  const form = document.getElementById('new-absence-form');
  const selectedDate = form?.querySelector('input[name="date"]')?.value || '';
  const schoolDayStart = form?.dataset.schoolDayStart || '';
  const schoolDayEnd = form?.dataset.schoolDayEnd || '';
  const quickButtons = Array.from(document.querySelectorAll('[data-fill]'));

  const setActivePreset = (preset) => {
    quickButtons.forEach((button) => {
      const active = button.dataset.fill === preset;
      button.classList.toggle('bg-indigo-600', active);
      button.classList.toggle('text-white', active);
      button.classList.toggle('shadow-sm', active);
      button.classList.toggle('text-gray-700', !active);
      button.classList.toggle('hover:bg-indigo-50', !active);
      button.classList.toggle('hover:text-indigo-700', !active);
      button.classList.toggle('hover:bg-indigo-700', active);
    });
  };

  const pad = (n) => String(n).padStart(2, '0');
  const format = (d) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  const dateParts = () => {
    const match = selectedDate.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!match) return null;
    return [Number(match[1]), Number(match[2]) - 1, Number(match[3])];
  };
  const selectedDateFromParts = () => {
    const parts = dateParts();
    if (!parts) return '';
    return `${parts[0]}-${pad(parts[1] + 1)}-${pad(parts[2])}`;
  };
  const inputDate = (value) => String(value || '').slice(0, 10);
  const timeForDate = (date, fallbackTime, scheduledValue) => {
    if (date && date === selectedDateFromParts() && scheduledValue) return scheduledValue;
    return date ? `${date}T${fallbackTime}` : '';
  };
  const schoolStartForDate = (date) => timeForDate(date, '09:00', schoolDayStart);
  const schoolEndForDate = (date) => timeForDate(date, '19:00', schoolDayEnd);

  const setToday = () => {
    const parts = dateParts();
    const date = parts ? selectedDateFromParts() : inputDate(format(new Date()));
    fromInput.value = schoolStartForDate(date);
    toInput.value = schoolEndForDate(date);
    setActivePreset('today');
  };

  const setDayEnd = () => {
    const currentStart = fromInput.value || schoolDayStart || format(new Date());
    const date = inputDate(currentStart) || selectedDateFromParts();
    const dayEnd = schoolEndForDate(date);
    const dayStart = schoolStartForDate(date);
    fromInput.value = currentStart >= dayEnd ? dayStart : currentStart;
    toInput.value = dayEnd;
    setActivePreset('day-end');
  };

  const setOneLesson = () => {
    const base = fromInput.value ? new Date(fromInput.value) : new Date();
    const end = new Date(base.getTime() + 45 * 60 * 1000);
    fromInput.value = format(base);
    toInput.value = format(end);
    setActivePreset('lesson');
  };

  document.querySelector('[data-fill="today"]')?.addEventListener('click', setToday);
  document.querySelector('[data-fill="day-end"]')?.addEventListener('click', setDayEnd);
  document.querySelector('[data-fill="lesson"]')?.addEventListener('click', setOneLesson);
  fromInput.addEventListener('input', () => setActivePreset(''));
  toInput.addEventListener('input', () => setActivePreset(''));
})();
</script>
