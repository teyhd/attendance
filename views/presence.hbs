<section data-presence-root data-date="{{board.date}}" class="space-y-3">
  <div class="rounded-md border border-gray-200 bg-white p-3">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-gray-950">Ручной ввод</h1>
        <div class="mt-1 text-sm text-gray-600">{{board.date_label}} · {{board.totals.present}} / {{board.totals.students}}</div>
      </div>
    </div>

    {{#if board.classes.length}}
      <div class="mt-3 flex gap-2 overflow-x-auto pb-1">
        {{#each board.classes}}
          <a href="#{{anchor}}" class="shrink-0 rounded border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-800 hover:border-gray-900">{{name}}</a>
        {{/each}}
      </div>
    {{/if}}
  </div>

  <div data-presence-flash class="hidden">
    <span data-presence-flash-text class="min-w-0 flex-1 truncate"></span>
    <button type="button" data-presence-cancel class="hidden shrink-0 rounded border border-current px-3 py-1.5 text-sm font-medium">Отменить</button>
  </div>

  {{#if board.classes.length}}
    <div class="space-y-3">
      {{#each board.classes}}
        <section id="{{anchor}}" data-presence-class class="scroll-mt-4 rounded-md border border-gray-200 bg-white">
          <div class="flex items-center justify-between border-b border-gray-200 px-3 py-2">
            <h2 class="text-lg font-semibold text-gray-950">{{name}}</h2>
            <span class="text-sm text-gray-500">{{students_label}}</span>
          </div>
          <div class="grid grid-cols-1 gap-2 p-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {{#each students}}
              <button
                type="button"
                data-presence-button
                data-student-id="{{id}}"
                data-class-id="{{classId}}"
                data-last-event-id="{{state.last_event_id}}"
                data-last-event-type="{{state.last_event_type}}"
                data-status-code="{{state.status_code}}"
                aria-label="{{name}} · {{state.status_label}}"
                class="min-h-[6.25rem] rounded-md border px-3 py-3 text-left shadow-sm transition focus:outline-none focus:ring-2 focus:ring-gray-900 disabled:cursor-wait disabled:opacity-60 {{#if (eq state.status_code "absent")}}border-red-300 bg-red-50 hover:bg-red-100{{else}}{{#if (eq state.status_code "late")}}border-amber-300 bg-amber-50 hover:bg-amber-100{{else}}{{#if (eq state.status_code "present")}}border-emerald-600 bg-emerald-50 hover:bg-emerald-100{{else}}{{#if (eq state.status_code "departed")}}border-slate-300 bg-slate-50 hover:bg-slate-100{{else}}border-gray-300 bg-white hover:bg-gray-50{{/if}}{{/if}}{{/if}}{{/if}}"
              >
                <span class="block text-base font-semibold leading-5 text-gray-950">{{name}}</span>
                <span data-presence-status class="mt-2 inline-flex rounded-full px-2 py-0.5 text-xs font-semibold {{#if (eq state.status_code "absent")}}bg-red-100 text-red-800{{else}}{{#if (eq state.status_code "late")}}bg-amber-100 text-amber-800{{else}}{{#if (eq state.status_code "present")}}bg-emerald-100 text-emerald-800{{else}}{{#if (eq state.status_code "departed")}}bg-slate-200 text-slate-700{{else}}bg-gray-100 text-gray-600{{/if}}{{/if}}{{/if}}{{/if}}">{{state.status_badge_label}}</span>
                <span data-presence-detail class="mt-1 block text-sm leading-4 text-gray-600">{{state.status_detail}}</span>
              </button>
            {{/each}}
          </div>
        </section>
      {{/each}}
    </div>
  {{else}}
    <div class="rounded-md border border-gray-200 bg-white p-4 text-sm text-gray-500">Нет учеников</div>
  {{/if}}
</section>

<script>
(() => {
  const root = document.querySelector('[data-presence-root]');
  if (!root) return;

  const buttons = Array.from(root.querySelectorAll('[data-presence-button]'));
  const flash = root.querySelector('[data-presence-flash]');
  const flashText = root.querySelector('[data-presence-flash-text]');
  const cancelButton = root.querySelector('[data-presence-cancel]');
  const flashBase = 'sticky top-2 z-20 flex items-center gap-3 rounded-md border px-3 py-2 text-sm shadow-sm';

  const eventLabel = (type) => type === 'departure' ? 'Ушёл' : 'Пришёл';
  const cardToneClasses = [
    'border-red-300', 'bg-red-50', 'hover:bg-red-100',
    'border-amber-300', 'bg-amber-50', 'hover:bg-amber-100',
    'border-emerald-600', 'bg-emerald-50', 'hover:bg-emerald-100',
    'border-slate-300', 'bg-slate-50', 'hover:bg-slate-100',
    'border-gray-300', 'bg-white', 'hover:bg-gray-50',
  ];
  const statusToneClasses = [
    'bg-red-100', 'text-red-800',
    'bg-amber-100', 'text-amber-800',
    'bg-emerald-100', 'text-emerald-800',
    'bg-slate-200', 'text-slate-700',
    'bg-gray-100', 'text-gray-600',
  ];
  const cardTone = {
    absent: ['border-red-300', 'bg-red-50', 'hover:bg-red-100'],
    late: ['border-amber-300', 'bg-amber-50', 'hover:bg-amber-100'],
    present: ['border-emerald-600', 'bg-emerald-50', 'hover:bg-emerald-100'],
    departed: ['border-slate-300', 'bg-slate-50', 'hover:bg-slate-100'],
    none: ['border-gray-300', 'bg-white', 'hover:bg-gray-50'],
  };
  const statusTone = {
    absent: ['bg-red-100', 'text-red-800'],
    late: ['bg-amber-100', 'text-amber-800'],
    present: ['bg-emerald-100', 'text-emerald-800'],
    departed: ['bg-slate-200', 'text-slate-700'],
    none: ['bg-gray-100', 'text-gray-600'],
  };
  const newKey = () => window.crypto?.randomUUID?.() || `${Date.now()}-${Math.random().toString(16).slice(2)}`;
  const currentLocalDate = () => {
    const date = new Date();
    const pad = (value) => String(value).padStart(2, '0');
    return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
  };
  const refreshIfDateChanged = () => {
    if (root.dataset.date && root.dataset.date !== currentLocalDate()) {
      window.location.reload();
    }
  };

  function setFlash(text, { kind = 'ok', eventId = '' } = {}) {
    if (!flash || !flashText) return;
    const kindClass = kind === 'error'
      ? 'border-red-200 bg-red-50 text-red-900'
      : 'border-emerald-200 bg-emerald-50 text-emerald-900';
    flash.className = `${flashBase} ${kindClass}`;
    flashText.textContent = text;
    if (cancelButton) {
      cancelButton.dataset.eventId = eventId;
      cancelButton.classList.toggle('hidden', !eventId);
    }
  }

  async function postJson(url, body = {}) {
    const response = await fetch(url, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(body),
    });
    const payload = await response.json().catch(() => ({}));
    if (!response.ok) {
      throw new Error(payload.message || payload.error || 'Не удалось сохранить');
    }
    return payload;
  }

  function applyState(button, state) {
    const status = button.querySelector('[data-presence-status]');
    const detail = button.querySelector('[data-presence-detail]');
    const statusCode = state?.status_code || (state?.is_present ? 'present' : 'none');
    button.dataset.lastEventId = state?.last_event_id || '';
    button.dataset.lastEventType = state?.last_event_type || '';
    button.dataset.statusCode = statusCode;
    button.setAttribute('aria-label', `${button.querySelector('.font-semibold')?.textContent || ''} · ${state?.status_label || 'Нет отметки'}`);

    status.textContent = state?.status_badge_label || state?.status_word || 'Нет отметки';
    if (detail) detail.textContent = state?.status_detail || state?.status_time || '';
    button.classList.remove(...cardToneClasses);
    button.classList.add(...(cardTone[statusCode] || cardTone.none));
    status.classList.remove(...statusToneClasses);
    status.classList.add(...(statusTone[statusCode] || statusTone.none));
  }

  buttons.forEach((button) => {
    button.addEventListener('click', async () => {
      if (button.disabled) return;
      button.disabled = true;
      try {
        const payload = await postJson('/api/attendance/presence/toggle', {
          studentId: button.dataset.studentId,
          classId: button.dataset.classId,
          idempotencyKey: newKey(),
        });
        if (payload.event?.attendance_date && payload.event.attendance_date !== root.dataset.date) {
          window.location.reload();
          return;
        }
        applyState(button, payload.state);
        const event = payload.event || {};
        setFlash(`${event.student_name || ''}: ${event.event_label || eventLabel(event.event_type)} ${event.occurred_label || event.occurred_time || ''}`.trim(), {
          eventId: event.id || '',
        });
      } catch (err) {
        setFlash(err.message || 'Не удалось сохранить', { kind: 'error' });
      } finally {
        button.disabled = false;
      }
    });
  });

  cancelButton?.addEventListener('click', async () => {
    const eventId = cancelButton.dataset.eventId || '';
    if (!eventId) return;
    cancelButton.disabled = true;
    try {
      const payload = await postJson(`/api/attendance/presence/events/${encodeURIComponent(eventId)}/cancel`);
      const event = payload.event || {};
      const button = buttons.find((item) => String(item.dataset.studentId) === String(event.student_id));
      if (button) applyState(button, payload.state);
      setFlash(`Отменено: ${event.student_name || ''}`.trim());
    } catch (err) {
      setFlash(err.message || 'Не удалось отменить', { kind: 'error' });
    } finally {
      cancelButton.disabled = false;
    }
  });

  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) refreshIfDateChanged();
  });
  window.addEventListener('focus', refreshIfDateChanged);
  window.setInterval(refreshIfDateChanged, 60_000);
})();
</script>
