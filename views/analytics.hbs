<style>
  #student-analytics-dialog::backdrop { background: rgba(15, 23, 42, 0.45); }
  @media print {
    .no-print { display: none !important; }
    body { background: #fff !important; }
    main { max-width: none !important; padding: 0 !important; }
    .shadow, .shadow-sm, .shadow-lg { box-shadow: none !important; }
  }
</style>

<section class="space-y-4">
  <div class="bg-white shadow rounded-lg p-4 space-y-4">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-3">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">Аналитика посещаемости</h1>
        <div class="mt-1 text-sm text-gray-600">{{analytics.month_label}} · {{analytics.class_name}}</div>
      </div>

      <form method="get" action="/attendance/analytics" data-analytics-controls class="no-print flex flex-col sm:flex-row gap-2 sm:items-end">
        <label class="text-sm text-gray-700">
          <span class="block mb-1">Месяц</span>
          <input name="month" value="{{analytics.month}}" type="month" class="w-full sm:w-40 rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" />
        </label>
        <label class="text-sm text-gray-700">
          <span class="block mb-1">Класс</span>
          <select name="class" class="w-full sm:w-44 rounded border-gray-300 focus:border-indigo-500 focus:ring-indigo-500">
            {{#each classOptions}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
        </label>
        <button type="button" data-print-analytics class="px-4 py-2 border rounded bg-white text-gray-700 hover:bg-gray-50">Печать</button>
        <button type="button" data-export-analytics class="px-4 py-2 border rounded bg-white text-gray-700 hover:bg-gray-50">CSV</button>
      </form>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
      {{#each kpiCards}}
        {{#if href}}
          <a href="{{href}}" data-kpi-card data-target-id="{{target_id}}" class="block border-l-4 {{border_class}} border rounded bg-white p-3 transition hover:-translate-y-0.5 hover:shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400 focus-visible:ring-offset-2">
            <div class="text-xs text-gray-500">{{label}}</div>
            <div class="mt-1 text-2xl font-semibold text-gray-900">{{value}}</div>
            {{#if hint}}<div class="mt-1 text-xs text-gray-500">{{hint}}</div>{{/if}}
            {{#if details}}
              <div class="mt-2 flex flex-wrap gap-1">
                {{#each details}}
                  <span class="rounded-full px-2 py-0.5 text-[11px] font-medium {{tone_class}}">{{label}}</span>
                {{/each}}
              </div>
            {{/if}}
            <div class="mt-2 text-xs font-medium text-indigo-700">{{action_label}}</div>
          </a>
        {{else}}
          <div class="border-l-4 {{border_class}} border rounded bg-white p-3">
            <div class="text-xs text-gray-500">{{label}}</div>
            <div class="mt-1 text-2xl font-semibold text-gray-900">{{value}}</div>
            {{#if hint}}<div class="mt-1 text-xs text-gray-500">{{hint}}</div>{{/if}}
            {{#if details}}
              <div class="mt-2 flex flex-wrap gap-1">
                {{#each details}}
                  <span class="rounded-full px-2 py-0.5 text-[11px] font-medium {{tone_class}}">{{label}}</span>
                {{/each}}
              </div>
            {{/if}}
          </div>
        {{/if}}
      {{/each}}
    </div>
  </div>

  {{#unless analytics.has_activity}}
    <div class="bg-white shadow rounded-lg p-6">
      <div class="text-base font-semibold text-gray-900">За выбранный месяц данных нет</div>
      <div class="mt-1 text-sm text-gray-500">Отчет готов к чтению, когда появятся записи посещаемости.</div>
    </div>
  {{else}}
    <div data-analytics-tabs data-default-tab="summary" class="space-y-4">
      <div class="no-print flex flex-wrap gap-2 border-b border-gray-200">
        <button type="button" data-analytics-tab="summary" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">Сводка</button>
        <button type="button" data-analytics-tab="lessons" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">Уроки</button>
        <button type="button" data-analytics-tab="lateness" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">Опоздания</button>
        <button type="button" data-analytics-tab="calendar" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">Календарь</button>
        <button type="button" data-analytics-tab="classes" class="rounded-t border border-b-0 px-3 py-2 text-sm font-medium">Классы</button>
      </div>

      <section data-analytics-panel="summary" class="space-y-4">
        <div id="today-absences" class="bg-white shadow rounded-lg p-4">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="text-base font-semibold text-gray-900">Отсутствующие</h2>
              <div class="mt-1 flex flex-wrap gap-1 text-xs">
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-gray-600">{{analytics.class_summary.absent_today_label}}</span>
                <span class="rounded-full {{#if analytics.class_summary.without_reason}}bg-amber-100 text-amber-800{{else}}bg-gray-100 text-gray-600{{/if}} px-2 py-0.5">без причины: {{analytics.class_summary.without_reason}}</span>
                <span class="rounded-full {{#if analytics.class_summary.needs_attention}}bg-red-100 text-red-800{{else}}bg-gray-100 text-gray-600{{/if}} px-2 py-0.5">внимание: {{analytics.class_summary.needs_attention}}</span>
                <span class="rounded-full {{#if analytics.class_summary.needs_clarification}}bg-yellow-100 text-yellow-800{{else}}bg-gray-100 text-gray-600{{/if}} px-2 py-0.5">уточнить: {{analytics.class_summary.needs_clarification}}</span>
              </div>
            </div>
          </div>
          {{#if analytics.today_absences.students}}
            <div class="mt-3 overflow-x-auto">
              <table class="min-w-full text-sm">
                <thead class="text-xs text-gray-500">
                  <tr class="border-b">
                    <th class="py-2 pr-3 text-left font-medium">Класс</th>
                    <th class="py-2 pr-3 text-left font-medium">Имя</th>
                    <th class="py-2 pr-3 text-left font-medium">Период</th>
                    <th class="py-2 text-left font-medium">Причина</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {{#each analytics.today_absences.students}}
                    <tr class="hover:bg-indigo-50">
                      <td class="py-2 pr-3 align-top text-gray-600">{{class_name}}</td>
                      <td class="py-2 pr-3 align-top font-medium text-gray-900">
                        <a href="{{href}}" class="hover:text-indigo-700">{{student_name}}</a>
                      </td>
                      <td class="py-2 pr-3 align-top text-gray-700">
                        <span>{{today_period_label}}</span>
                        {{#if period_count_label}}
                          <span class="ml-1 rounded-full bg-gray-100 px-1.5 py-0.5 text-xs text-gray-600">{{period_count_label}}</span>
                        {{/if}}
                      </td>
                      <td class="py-2 align-top text-gray-700">
                        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-700">{{reason_name}}</span>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{else}}
            <div class="mt-3 rounded border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-500">Нет</div>
          {{/if}}
        </div>

        {{#if analytics.quality.has_issues}}
          <div id="data-quality" class="bg-white shadow rounded-lg p-4 min-w-0">
            <h2 class="text-base font-semibold text-gray-900">Качество данных</h2>
            <div class="mt-3 grid sm:grid-cols-3 gap-2">
              {{#each analytics.quality.issues}}
                <div class="border rounded p-3 bg-amber-50 border-amber-200">
                  <div class="text-xs text-amber-800">{{label}}</div>
                  <div class="mt-1 text-xl font-semibold text-amber-900">{{value}}</div>
                </div>
              {{/each}}
            </div>
          </div>
        {{/if}}

        <div id="reasons-breakdown" class="bg-white shadow rounded-lg p-4">
          <h2 class="text-base font-semibold text-gray-900">Причины</h2>
          <div class="mt-4 space-y-3">
            {{#each analytics.reasons}}
              <div>
                <div class="flex items-center justify-between gap-2 text-sm">
                  <span class="font-medium text-gray-900">{{name}}</span>
                  <span class="text-gray-500">{{absence_days}} дн. · {{percent}}%</span>
                </div>
                <div class="mt-1 h-2 rounded-full bg-gray-100 overflow-hidden">
                  <div class="h-2 rounded-full" style="width: {{bar_width}}%; background-color: {{bar_color}};"></div>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      </section>

      <section data-analytics-panel="lessons" id="learning-analytics" class="hidden bg-white shadow rounded-lg p-4 space-y-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-base font-semibold text-gray-900">Пропущенные уроки</h2>
          <div class="mt-1 text-sm text-gray-500">По опубликованному расписанию, пересечение больше 15 минут</div>
        </div>
        <div class="grid grid-cols-2 gap-2 text-center sm:grid-cols-4">
          <div class="border rounded px-3 py-2">
            <div class="text-lg font-semibold text-gray-900">{{analytics.learning.missed_lessons_total}}</div>
            <div class="text-xs text-gray-500">уроков</div>
          </div>
          <div class="border rounded px-3 py-2">
            <div class="text-lg font-semibold text-gray-900">{{analytics.learning.students_with_missed_lessons}}</div>
            <div class="text-xs text-gray-500">учеников</div>
          </div>
          <div class="border rounded px-3 py-2">
            <div class="text-lg font-semibold text-gray-900">{{analytics.learning.subjects_total}}</div>
            <div class="text-xs text-gray-500">предметов</div>
          </div>
          <div class="border rounded px-3 py-2">
            <div class="text-lg font-semibold {{#if analytics.learning.uncovered_absence_periods}}text-red-700{{else}}text-emerald-700{{/if}}">{{analytics.learning.coverage_percent}}%</div>
            <div class="text-xs text-gray-500">покрытие</div>
          </div>
        </div>
      </div>

      {{#if analytics.learning.data_gaps_total}}
        <div class="rounded border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900">
          Отметки без опубликованного расписания: {{analytics.learning.uncovered_absence_periods}}. Дней без расписания: {{analytics.learning.data_gaps_total}}.
        </div>
      {{/if}}

      <div class="grid gap-4 xl:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold text-gray-900">Предметы</h3>
          {{#if analytics.learning.subjects}}
            <div class="mt-3 space-y-3">
              {{#each analytics.learning.subjects}}
                <div>
                  <div class="flex items-center justify-between gap-2 text-sm">
                    <span class="font-medium text-gray-900">{{subject_name}}</span>
                    <span class="text-gray-500">{{missed_lessons}} · {{students}} уч.</span>
                  </div>
                  <div class="mt-1 h-2 rounded-full bg-gray-100 overflow-hidden">
                    <div class="h-2 rounded-full bg-indigo-600" style="width: {{bar_width}}%;"></div>
                  </div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="mt-2 text-sm text-gray-500">Пропущенных уроков по предметам нет.</p>
          {{/if}}
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-900">Ученики</h3>
          {{#if analytics.learning.students}}
            <div class="mt-3 overflow-x-auto">
              <table class="min-w-full text-sm">
                <thead class="text-xs text-gray-500">
                  <tr class="border-b">
                    <th class="py-2 pr-3 text-left font-medium">Ученик</th>
                    <th class="py-2 pr-3 text-left font-medium">Класс</th>
                    <th class="py-2 pr-3 text-right font-medium">Уроки</th>
                    <th class="py-2 pr-3 text-right font-medium">Предм.</th>
                    <th class="py-2 text-right font-medium">Без расп.</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {{#each analytics.learning.students}}
                    <tr>
                      <td class="py-2 pr-3 font-medium text-gray-900"><a href="{{href}}" class="hover:text-indigo-700">{{student_name}}</a></td>
                      <td class="py-2 pr-3 text-gray-600">{{class_name}}</td>
                      <td class="py-2 pr-3 text-right text-gray-900">{{missed_lessons}}</td>
                      <td class="py-2 pr-3 text-right text-gray-700">{{subjects}}</td>
                      <td class="py-2 text-right {{#if data_gaps}}text-red-700{{else}}text-gray-500{{/if}}">{{data_gaps}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{else}}
            <p class="mt-2 text-sm text-gray-500">Учеников с пропущенными уроками нет.</p>
          {{/if}}
        </div>
      </div>

      <div class="grid gap-4 xl:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold text-gray-900">Классы</h3>
          {{#if analytics.learning.classes}}
            <div class="mt-3 space-y-3">
              {{#each analytics.learning.classes}}
                <div>
                  <div class="flex items-center justify-between gap-2 text-sm">
                    <span class="font-medium text-gray-900">{{class_name}}</span>
                    <span class="text-gray-500">{{missed_lessons}} · {{students}} уч. · {{subjects}} предм.</span>
                  </div>
                  <div class="mt-1 h-2 rounded-full bg-gray-100 overflow-hidden">
                    <div class="h-2 rounded-full bg-sky-600" style="width: {{bar_width}}%;"></div>
                  </div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="mt-2 text-sm text-gray-500">Классов с пропущенными уроками нет.</p>
          {{/if}}
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-900">Дни</h3>
          <div class="mt-3 grid sm:grid-cols-2 xl:grid-cols-3 gap-2">
            {{#each analytics.learning.daily}}
              {{#if missed_lessons}}
                <div class="flex items-center gap-2 text-sm">
                  <div class="w-16 text-gray-500">{{date_label}}</div>
                  <div class="flex-1 h-2 rounded-full bg-gray-100 overflow-hidden">
                    <div class="h-2 rounded-full bg-indigo-600" style="width: {{bar_width}}%;"></div>
                  </div>
                  <div class="w-8 text-right font-medium text-gray-900">{{missed_lessons}}</div>
                </div>
              {{/if}}
            {{/each}}
          </div>
        </div>
      </div>
      </section>

      <section data-analytics-panel="lateness" id="lateness-analytics" class="hidden bg-white shadow rounded-lg p-4 space-y-4">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <h2 class="text-base font-semibold text-gray-900">Опоздания</h2>
          <div class="grid grid-cols-2 gap-2 text-center sm:grid-cols-4">
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold text-gray-900">{{analytics.lateness.late_days_total}}</div>
              <div class="text-xs text-gray-500">опозданий</div>
            </div>
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold text-gray-900">{{analytics.lateness.students_late_total}}</div>
              <div class="text-xs text-gray-500">учеников</div>
            </div>
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold text-gray-900">{{analytics.lateness.missed_lessons_total}}</div>
              <div class="text-xs text-gray-500">уроков</div>
            </div>
            <div class="border rounded px-3 py-2">
              <div class="text-lg font-semibold {{#if analytics.lateness.data_gaps_total}}text-red-700{{else}}text-gray-900{{/if}}">{{analytics.lateness.avg_late_minutes}}</div>
              <div class="text-xs text-gray-500">сред. мин.</div>
            </div>
          </div>
        </div>

        {{#if analytics.lateness.data_gaps_total}}
          <div class="rounded border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900">
            Без расписания по присутствию: {{analytics.lateness.data_gaps_total}}. Покрытие: {{analytics.lateness.coverage.coverage_percent}}%.
          </div>
        {{/if}}

        <div class="grid gap-4 xl:grid-cols-2">
          <div>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <h3 class="text-sm font-semibold text-gray-900">Классы и дети</h3>
              <div class="flex flex-col gap-2 sm:items-end">
                <div class="flex flex-wrap gap-1" data-lateness-filter-group>
                  <button type="button" data-lateness-filter="all" class="rounded border px-2.5 py-1.5 text-xs font-medium">Все</button>
                  <button type="button" data-lateness-filter="late" class="rounded border px-2.5 py-1.5 text-xs font-medium">Опоздали</button>
                  <button type="button" data-lateness-filter="on_time" class="rounded border px-2.5 py-1.5 text-xs font-medium">Вовремя</button>
                  <button type="button" data-lateness-filter="gap" class="rounded border px-2.5 py-1.5 text-xs font-medium">Без расписания</button>
                </div>
                <label class="sr-only" for="lateness-sort">Сортировка</label>
                <select id="lateness-sort" data-lateness-sort class="rounded border-gray-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
                  <option value="late_first">Сначала опоздавшие</option>
                  <option value="arrived_first">Сначала присутствующие</option>
                  <option value="minutes">Минуты опоздания</option>
                  <option value="name">Имя</option>
                </select>
              </div>
            </div>
            {{#if analytics.lateness.classes}}
              <div class="mt-3 space-y-3" data-lateness-classes>
                {{#each analytics.lateness.classes}}
                  <section data-lateness-class class="rounded border border-gray-200 bg-white">
                    <div class="flex flex-col gap-1 border-b border-gray-100 px-3 py-2 sm:flex-row sm:items-center sm:justify-between">
                      <div class="font-semibold text-gray-900">Класс {{class_name}}</div>
                      <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500">
                        <span><span data-lateness-class-visible>{{students_total}}</span> / {{students_total}}</span>
                        <span>опозд.: {{students_late}}</span>
                        <span>вовремя: {{students_on_time}}</span>
                        {{#if students_gap}}<span class="text-red-700">без расписания: {{students_gap}}</span>{{/if}}
                      </div>
                    </div>
                    <div class="divide-y divide-gray-100" data-lateness-student-list>
                      {{#each students}}
                        <div
                          data-lateness-student
                          data-lateness-status="{{status_code}}"
                          data-lateness-name="{{student_name}}"
                          data-lateness-arrivals="{{arrival_days}}"
                          data-lateness-on-time-days="{{on_time_days}}"
                          data-lateness-late-days="{{late_days}}"
                          data-lateness-minutes="{{total_late_minutes}}"
                          data-lateness-gaps="{{data_gaps}}"
                          class="grid gap-2 px-3 py-2 text-sm sm:grid-cols-[minmax(0,1fr)_auto]"
                        >
                          <div class="min-w-0">
                            <button type="button" class="font-medium text-gray-900 hover:text-indigo-700" data-student-analytics-open data-student-id="{{student_id}}">{{student_name}}</button>
                            <div class="mt-1 flex flex-wrap gap-1 text-xs">
                              <span class="rounded-full px-2 py-0.5 {{status_class}}">{{status_label}}</span>
                              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-gray-700">присутствие: {{arrival_days}}</span>
                              <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-emerald-700">вовремя: {{on_time_days}}</span>
                              <span class="rounded-full bg-amber-50 px-2 py-0.5 text-amber-800">опозд.: {{late_days}}</span>
                              {{#if data_gaps}}<span class="rounded-full bg-red-50 px-2 py-0.5 text-red-700">без расписания: {{data_gaps}}</span>{{/if}}
                            </div>
                          </div>
                          <div class="text-left text-xs text-gray-600 sm:text-right">
                            <div>{{detail_label}}</div>
                            <div class="mt-0.5">{{total_late_minutes}} мин. · {{missed_lessons}} ур.</div>
                          </div>
                        </div>
                      {{/each}}
                    </div>
                  </section>
                {{/each}}
              </div>
            {{else}}
              <p class="mt-2 text-sm text-gray-500">Присутствия за период нет.</p>
            {{/if}}
          </div>

          <div>
            <h3 class="text-sm font-semibold text-gray-900">Предметы</h3>
            {{#if analytics.lateness.subjects}}
              <div class="mt-3 space-y-3">
                {{#each analytics.lateness.subjects}}
                  <div>
                    <div class="flex items-center justify-between gap-2 text-sm">
                      <span class="font-medium text-gray-900">{{subject_name}}</span>
                      <span class="text-gray-500">{{missed_lessons}} · {{students}} уч.</span>
                    </div>
                    <div class="mt-1 h-2 rounded-full bg-gray-100 overflow-hidden">
                      <div class="h-2 rounded-full bg-amber-600" style="width: {{bar_width}}%;"></div>
                    </div>
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="mt-2 text-sm text-gray-500">Пропущенных предметов из-за опозданий нет.</p>
            {{/if}}
          </div>
        </div>

      </section>

      <section data-analytics-panel="calendar" id="absence-calendar" class="hidden bg-white shadow rounded-lg p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-base font-semibold text-gray-900">Календарь отсутствий</h2>
          <span class="text-sm text-gray-500">ученик-день</span>
        </div>
        <div class="mt-4 grid grid-cols-7 gap-1">
          {{#each analytics.daily_calendar_weekdays}}
            <div class="pb-1 text-center text-[11px] font-medium text-gray-500">{{this}}</div>
          {{/each}}
          {{#each analytics.daily_calendar}}
            {{#if is_empty}}
              <div class="min-h-[4.75rem] sm:min-h-[5.25rem] rounded border border-transparent"></div>
            {{else}}
