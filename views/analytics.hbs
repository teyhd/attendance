                        <button type="button" class="rounded border border-gray-200 px-3 py-1.5 text-left text-xs text-gray-700 hover:bg-gray-50" data-student-analytics-open data-student-id="{{student_id}}" data-student-open-tab="days" data-student-open-mode="all">{{metric_label}}</button>
